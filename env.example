# oidc-test-sandbox — environment overrides
# Copy to `.env` and edit. All values have safe dev defaults in
# docker-compose.yml / keycloak/import.json, so `.env` is optional.

# ─── image tags ──────────────────────────────────────────────────
KEYCLOAK_VERSION=26.0
OUTLINE_VERSION=latest

# ─── Keycloak admin ──────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ─── database passwords ──────────────────────────────────────────
POSTGRES_KEYCLOAK_PASSWORD=keycloak_password
POSTGRES_OUTLINE_PASSWORD=outline_password

# ─── Flask / OIDC client secrets ─────────────────────────────────
# Must match the `secret` values in keycloak/import.json if you change them.
CLAIM_INSPECTOR_FLASK_SECRET=dev-flask-secret-change-me
CLAIM_INSPECTOR_SECRET=claim-inspector-dev-secret-change-me
RP_CLI_SECRET=rp-cli-dev-secret-change-me
OUTLINE_OIDC_SECRET=outline-dev-secret-change-me

# ─── SAML SP (stest-app) ────────────────────────────────────────
# Flask session secret for the SAML assertion inspector. The SP's
# signing keypair lives in saml-inspector/keys/ and is pre-committed
# (dev only — regenerate for any non-sandbox use).
SAML_INSPECTOR_FLASK_SECRET=dev-flask-secret-change-me-saml

# ─── Outline app-level secrets (generate with: openssl rand -hex 32) ─
OUTLINE_SECRET_KEY=ccb7a7928761a70efce6a9faf5976d6971c1f5fc88cdf675b41462bd164e90db
OUTLINE_UTILS_SECRET=46849b317bd836c343737b3d6a60507cc17e4e6c93e737ac6557cea10692ee40
